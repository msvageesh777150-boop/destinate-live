<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Destin-Ate Cake Cafe</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <!-- TOP PROMO -->
  <div class="promo-bar">
    Use Code <strong>FIRST10</strong> for 10% OFF your first order! | 100% EGGLESS AVAILABLE
  </div>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <div class="logo">Destin-ate</div>
      <div class="nav-links">
        <a href="/#home" onclick="if(window.location.pathname==='/'){event.preventDefault(); smoothScroll('#home')}">HOME</a>
        <a href="/#menu" onclick="if(window.location.pathname==='/'){event.preventDefault(); smoothScroll('#menu')}">MENU</a>
        <a href="/#bestsellers" onclick="if(window.location.pathname==='/'){event.preventDefault(); smoothScroll('#bestsellers')}">BESTSELLERS</a>
        <a href="/#about" onclick="if(window.location.pathname==='/'){event.preventDefault(); smoothScroll('#about')}">ABOUT</a>
        <a href="/#contact" onclick="if(window.location.pathname==='/'){event.preventDefault(); smoothScroll('#contact')}">CONTACT</a>
      </div>
    </div>
  </nav>

  <!-- CART UI -->
  <div id="cart-float" class="cart-float hidden" onclick="toggleCart()">
    <span class="cart-icon">🛒</span>
    <span class="cart-badge" id="cart-badge">0</span>
  </div>

  <div id="cart-overlay" class="cart-overlay hidden" onclick="toggleCart()"></div>
  <div id="cart-sidebar" class="cart-sidebar">
    <div class="cart-header">
      <h3>Your Order</h3>
      <button onclick="toggleCart()" class="cart-close">×</button>
    </div>
    <div class="cart-items" id="cart-items"></div>
    <div class="cart-footer">
      <div class="cart-row">
        <input type="text" id="coupon-code" placeholder="Coupon Code (e.g. FIRST10)" style="padding: 8px; border: 1px solid var(--beige-dark); border-radius: 4px; width: 60%; font-family: 'Jost', sans-serif;">
        <button onclick="applyCoupon()" class="btn-outline" style="padding: 8px 12px;">Apply</button>
      </div>
      <div class="cart-row"><span>Subtotal</span><span id="cart-subtotal">₹0</span></div>
      <div class="cart-row"><span>Delivery Fee</span><span id="cart-delivery">₹40</span></div>
      <div class="cart-row" id="discount-row" style="display:none; color: var(--accent);"><span>Discount</span><span id="cart-discount">-₹0</span></div>
      <div class="cart-row total"><span>Total</span><span id="cart-total">₹0</span></div>
      <button class="btn-primary" style="width: 100%; margin-top: 1rem; padding: 16px" onclick="openCheckout()">Proceed to Checkout</button>
    </div>
  </div>

  <div id="checkout-modal" class="checkout-modal hidden">
    <div class="checkout-content">
      <div class="checkout-header">
        <h2>Secure Checkout</h2>
        <button onclick="closeCheckout()" class="checkout-close">×</button>
      </div>
      <form id="payment-form" onsubmit="processPayment(event)">
        <div class="form-group"><label>Name</label><input type="text" id="chk-name" required placeholder="John Doe"></div>
        <div class="form-group"><label>Phone Number</label><input type="tel" id="chk-phone" required placeholder="+91 XXXXX XXXXX"></div>
        <div class="form-group"><label>Full Delivery Address</label><textarea id="chk-address" required placeholder="House No, Street name, Area..."></textarea></div>
        <div class="form-row">
            <div class="form-group">
                <label>Payment Method</label>
                <select id="chk-method">
                    <option value="UPI">UPI / GPay / PhonePe</option>
                    <option value="Card">Credit / Debit Card</option>
                    <option value="COD">Cash on Delivery</option>
                </select>
            </div>
            <div class="form-group">
                <label>Amount to Pay</label>
                <input type="text" id="chk-amount" disabled style="font-weight:bold; color:var(--sage); background:var(--sage-pale); border-color:var(--sage-mid);">
            </div>
        </div>
        <button type="submit" class="btn-primary" style="width: 100%; padding: 16px; font-size:1rem;" id="pay-btn">Pay & Place Order</button>
      </form>
      <div id="processing-overlay" class="processing-overlay hidden">
          <div class="spinner"></div>
          <h3 id="processing-msg">Processing Payment...</h3>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>
