<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Area | Destin-Ate</title>
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --sage: #8B4513;
      --beige-dark: #EAE6DF;
      --text-muted: #8E8E93;
      --cream: #FDFBF7;
    }
    body { background: var(--cream); font-family: 'Jost', sans-serif; margin:0; padding:0; }
    .admin-nav { background: var(--sage); color: white; padding: 20px; display:flex; justify-content: space-between; align-items:center; }
    .admin-nav h2 { margin: 0; font-family: 'Playfair Display', serif; font-weight: 600; }
    .admin-nav a { color: white; text-decoration: none; border: 1px solid white; padding: 5px 15px; border-radius: 4px; }
    .container { max-width: 1200px; margin: 40px auto; padding: 0 20px; display: grid; gap: 30px; }
    .card { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    table { width: 100%; border-collapse: collapse; margin-top: 15px; }
    th, td { text-align: left; padding: 15px; border-bottom: 1px solid var(--beige-dark); }
    th { color: var(--text-muted); font-weight: 500; text-transform: uppercase; font-size: 0.85rem; }
    .status-select { padding: 5px; border-radius: 4px; border: 1px solid var(--beige-dark); font-family: 'Jost', sans-serif; }
    .btn-update { background: var(--sage); color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; margin-top: 5px; font-size: 0.8rem; }
  </style>
</head>
<body>
  <div class="admin-nav">
    <h2>Destin-Ate Admin Dashboard</h2>
    <div>
      <a href="/" style="margin-right: 10px;">← Back to Site</a>
      <a href="/logout" style="background: white; color: var(--sage);">Logout</a>
    </div>
  </div>

<% 
    const isCustomCake = (o) => o.method === 'Custom Cake' || o.occasion || (o.items && o.items.length > 0 && o.items[0].name === 'Custom Cake');
    const ecommerceOrders = orders.filter(o => o.items && o.items.length > 0 && !isCustomCake(o));
    const customCakeOrders = orders.filter(o => isCustomCake(o));
%>

  <div class="container">
    <div class="card">
        <h3>E-Commerce Orders</h3>
        <% if(ecommerceOrders.length === 0) { %>
            <div style="padding: 40px; text-align:center; color:var(--text-muted)">No e-commerce orders received yet!</div>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Address</th>
                        <th>Total Amount</th>
                        <th>Items</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% ecommerceOrders.forEach(o => { %>
                        <tr>
                            <td style="font-size: 0.8rem;">#<%= o._id %></td>
                            <td><strong><%= o.name %></strong><br><span style="font-size:0.85rem;color:gray"><%= o.phone %></span></td>
                            <td style="max-width: 200px;"><%= o.address %> <br><span style="font-size:0.8rem;color:gray">Via <%= o.method %> | <%= o.paymentStatus %></span></td>
                            <td style="font-weight:600; color:var(--sage)"><%= o.total %></td>
                            <td style="max-width: 250px; font-size:0.9rem;">
                                <% if(o.items && o.items.length) { %>
                                    <ul style="margin:0; padding-left:20px;">
                                    <% o.items.forEach(item => { %>
                                        <li><%= item.qty %>x <%= item.name %></li>
                                    <% }) %>
                                    </ul>
                                <% } %>
                            </td>
                            <td>
                              <select class="status-select" id="status-<%= o._id %>">
                                <option value="Pending" <%= o.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                <option value="Preparing" <%= o.status === 'Preparing' ? 'selected' : '' %>>Preparing</option>
                                <option value="Completed" <%= o.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                              </select>
                              <br>
                              <button class="btn-update" onclick="updateStatus('<%= o._id %>')">Update</button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>
    
    <div class="card" style="margin-top: 20px;">
        <h3>Custom Cake Requests</h3>
        <% if(customCakeOrders.length > 0) { %>
            <table>
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Contact</th>
                        <th>Details</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% customCakeOrders.forEach(o => { 
                        let cc = o.items[0] || {};
                    %>
                        <tr>
                            <td style="font-size: 0.8rem;">#<%= o._id %></td>
                            <td><strong><%= o.name %></strong></td>
                            <td style="font-size:0.85rem;"><%= o.phone %></td>
                            <td style="max-width:350px; font-size:0.9rem; white-space: pre-wrap;"><strong>Occasion:</strong> <%= cc.occasion %><br><strong>Flavour:</strong> <%= cc.flavour %><br><strong>Weight:</strong> <%= cc.weight %><br><strong>Delivery:</strong> <%= cc.delivery_date %> at <%= cc.delivery_time %><br><strong>Instructions:</strong> <%= o.message || '' %><% if(o.image_url) { %><br><a href="<%= o.image_url %>" target="_blank" style="color:var(--sage); text-decoration:underline;">View Reference Image</a><% } %></td>
                            <td>
                              <select class="status-select" id="status-<%= o._id %>">
                                <option value="Pending" <%= o.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                <option value="Preparing" <%= o.status === 'Preparing' ? 'selected' : '' %>>Preparing</option>
                                <option value="Completed" <%= o.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                              </select>
                              <br>
                              <button class="btn-update" onclick="updateStatus('<%= o._id %>')">Update</button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <div style="padding: 40px; text-align:center; color:var(--text-muted)">No custom cake requests!</div>
        <% } %>
    </div>

    <div class="card" style="margin-top: 20px;">
      <h3>General Inquiries</h3>
      <% if(messages && messages.length > 0) { %>
          <table>
              <thead>
                  <tr>
                      <th>Date</th>
                      <th>Name</th>
                      <th>Contact</th>
                      <th>Message</th>
                  </tr>
              </thead>
              <tbody>
                  <% messages.forEach(m => { %>
                      <tr>
                          <td style="font-size:0.85rem;color:gray"><%= new Date(m.createdAt || m.created_at || Date.now()).toLocaleDateString() %></td>
                          <td><strong><%= m.name %></strong></td>
                          <td style="font-size:0.85rem;"><%= m.phone %><br><%= m.email !== 'N/A' ? m.email : '' %></td>
                          <td style="max-width:350px; font-size:0.9rem; white-space: pre-wrap;"><%= m.body %></td>
                      </tr>
                  <% }) %>
              </tbody>
          </table>
      <% } else { %>
          <div style="padding: 40px; text-align:center; color:var(--text-muted)">No inquiries received yet!</div>
      <% } %>
  </div>
  </div>

  <script>
    async function updateStatus(id) {
      const status = document.getElementById('status-' + id).value;
      try {
        const res = await fetch('/api/admin/order/' + id + '/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status })
        });
        if(res.ok) {
          alert('Status updated successfully!');
        } else {
          alert('Failed to update status.');
        }
      } catch(err) {
        alert('Error connecting to server.');
      }
    }
  </script>
</body>
</html>
