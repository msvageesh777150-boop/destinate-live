<%- include('../partials/header') %>
<section style="min-height: 80vh; padding-top: 120px; background: var(--cream);">
  <div style="max-width: 600px; margin: 0 auto; background: white; padding: 3rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
    <h2 style="font-family: 'Playfair Display', serif; color: var(--brown); text-align: center; margin-bottom: 2rem;">Order Tracking</h2>
    <% if (error) { %>
      <div style="text-align: center; color: var(--accent);"><%= error %></div>
    <% } else if (order) { %>
      <div style="text-align: center; margin-bottom: 2rem;">
        <p style="color: var(--text-muted); font-size: 0.9rem;">Order ID: <strong><%= order._id %></strong></p>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Placed on: <%= new Date(order.createdAt).toLocaleString() %></p>
      </div>
      
      <!-- Progress Bar -->
      <div style="display: flex; justify-content: space-between; position: relative; margin-bottom: 3rem;">
        <div style="position: absolute; top: 15px; left: 0; right: 0; height: 3px; background: var(--beige-dark); z-index: 1;"></div>
        
        <% 
           let stages = ['Pending', 'Preparing', 'Completed']; 
           let currentIndex = stages.indexOf(order.status);
           if (currentIndex === -1) currentIndex = 0;
           
           let fillWidth = currentIndex === 0 ? '0%' : (currentIndex === 1 ? '50%' : '100%');
        %>
        <div style="position: absolute; top: 15px; left: 0; width: <%= fillWidth %>; height: 3px; background: var(--sage); z-index: 2; transition: width 0.5s;"></div>

        <% stages.forEach((stage, index) => { %>
          <div style="position: relative; z-index: 3; text-align: center; width: 60px;">
            <div style="width: 32px; height: 32px; border-radius: 50%; background: <%= index <= currentIndex ? 'var(--sage)' : 'var(--beige-dark)' %>; color: white; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; font-size: 0.8rem; font-weight: bold;">
              <%= index + 1 %>
            </div>
            <div style="font-size: 0.75rem; color: <%= index <= currentIndex ? 'var(--brown)' : 'var(--text-muted)' %>; font-weight: <%= index <= currentIndex ? '600' : '400' %>;">
              <%= stage %>
            </div>
          </div>
        <% }) %>
      </div>

      <div style="border-top: 1px solid var(--beige-dark); padding-top: 2rem;">
        <h4 style="color: var(--brown); margin-bottom: 1rem;">Order Details</h4>
        <p style="font-size: 0.9rem; color: var(--text); margin-bottom: 0.5rem;"><strong>Name:</strong> <%= order.name %></p>
        <p style="font-size: 0.9rem; color: var(--text); margin-bottom: 0.5rem;"><strong>Total:</strong> Rs. <%= order.total %></p>
        <p style="font-size: 0.9rem; color: var(--text); margin-bottom: 0.5rem;"><strong>Payment:</strong> <%= order.paymentStatus %></p>
        <div style="margin-top: 1rem;">
          <strong style="font-size: 0.9rem; color: var(--text);">Items:</strong>
          <ul style="list-style: none; padding: 0; margin-top: 0.5rem;">
            <% order.items.forEach(item => { %>
              <li style="font-size: 0.85rem; color: var(--text-muted); padding: 5px 0; border-bottom: 1px solid var(--cream);">
                <%= item.qty %>x <%= item.name %>
              </li>
            <% }) %>
          </ul>
        </div>
      </div>
    <% } %>
  </div>
</section>
<%- include('../partials/footer') %>
