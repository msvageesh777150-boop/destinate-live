    </p>  <!-- CHANGE DESCRIPTION -->
    <div class="hero-btns">
      <button class="btn-primary" onclick="smoothScroll('#custom-cakes')">Order Custom Cake</button>
      <button class="btn-outline" onclick="window.open('https://wa.me/919384784409?text=Hi! I would like to order a cake.', '_blank')">Chat on WhatsApp</button>
