============================================================ -->
<section id="menu">
  <div class="menu-header">
    <div>
      <div class="section-tag">Our Menu</div>
      <h2 class="section-title">Crafted with <em style="font-family:'Playfair Display',serif;font-style:italic;color:var(--sage)">Passion</em></h2>
