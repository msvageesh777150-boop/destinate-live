  </div>
  <div class="hero-visual">
    <div style="width: 100%; max-width: 380px; aspect-ratio: 1 / 1; border-radius: 50%; overflow: hidden; display: flex; justify-content: center; align-items: center; background: white; animation: float 6s ease-in-out infinite; box-shadow: 0 20px 50px rgba(74,124,89,0.15);">
