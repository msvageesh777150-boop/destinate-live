<!-- ============================================================
     ABOUT SECTION
     HOW TO EDIT:
     - Change the quote and founder name
     - Change the 4 mini card icons/titles/descriptions
     - Change the about text paragraphs
     - Change the values list items
============================================================ -->
<section id="about">
  <div class="about-grid">
    <div>
      <div class="about-card-main">
        <span class="about-icon">👩🍳</span>  <!-- CHANGE ICON -->
        <p class="about-quote">"We don't just bake cakes — we bake memories, moments, and a little bit of magic."</p>  <!-- CHANGE QUOTE -->
        <div class="about-author">— Founder, Destin-Ate Cake Cafe</div>  <!-- CHANGE NAME -->
      </div>
      <div class="about-mini-cards">
        <!-- EDIT EACH MINI CARD: icon, title, description -->
        <div class="about-mini"><div class="about-mini-icon">🌿</div><h4>Natural Ingredients</h4><p>No artificial preservatives or colours</p></div>
        <div class="about-mini"><div class="about-mini-icon">🤍</div><h4>Made with Love</h4><p>Every layer, every swirl, by hand</p></div>
        <div class="about-mini"><div class="about-mini-icon">🎁</div><h4>Gift-Ready</h4><p>Beautiful packaging for every occasion</p></div>
        <div class="about-mini"><div class="about-mini-icon">🚚</div><h4>Local Delivery</h4><p>Fresh to your door in Coimbatore</p></div>
      </div>
    </div>
    <div class="about-text">
      <div class="section-tag">Our Story</div>
      <h2 class="section-title">A Sweet Beginning</h2>
      <p>Destin-Ate was born from a simple belief: that every person deserves a cake that feels like it was made just for them. Founded in Coimbatore, we started as a small home bakery with big dreams.</p>  <!-- CHANGE STORY -->
      <h3>Our Philosophy</h3>
      <p>We source the finest local ingredients, work with seasonal flavours, and believe that a great cake should tell a story. Whether it is a simple slice of chai-spiced cake or a towering wedding centerpiece — we put our heart into every bake.</p>
      <div class="values-list">
        <!-- ADD/REMOVE VALUES: copy a .value-item div -->
        <div class="value-item"><div class="value-dot"></div>Freshly baked every morning, never day-old</div>
        <div class="value-item"><div class="value-dot"></div>No artificial colours or preservatives</div>
        <div class="value-item"><div class="value-dot"></div>Customisation for every dietary need</div>
        <div class="value-item"><div class="value-dot"></div>Eco-friendly packaging</div>
      </div>
    </div>
  </div>
</section>



