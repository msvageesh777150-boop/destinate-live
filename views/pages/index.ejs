<!-- ============================================================
     CUSTOM CAKES SECTION
     HOW TO EDIT:
     - Change step titles and descriptions
     - Add/remove form fields in the form card
     - Change dropdown options in <select> elements
============================================================ -->
<section id="custom-cakes">
  <div class="custom-grid">
    <div>
      <div class="section-tag">Custom Orders</div>
      <h2 class="section-title">Your Dream Cake, Crafted</h2>
      <p class="section-sub">Celebrate every milestone with a cake designed just for you — from concept to creation, we bring your vision to life.</p>
      <div class="custom-steps">
        <!-- EDIT STEPS: change h4 title and p description -->
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-content">
            <h4>Choose Your Base</h4>
            <p>Select from vanilla, chocolate, red velvet, matcha, and more</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-content">
            <h4>Pick Your Flavour</h4>
            <p>Mix and match fillings — fresh fruit, ganache, cream cheese</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-content">
            <h4>Design & Decorate</h4>
            <p>Share your theme, message, or inspiration with us</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">4</div>
          <div class="step-content">
            <h4>Delivered Fresh</h4>
            <p>Pick up in-store or get doorstep delivery in Coimbatore</p>
          </div>
        </div>
      </div>
    </div>
    <div class="custom-form-card">
      <div class="form-title">Request a Custom Cake</div>
      <form id="orderForm" onsubmit="handleCustomCakeSubmit(event)">
        <div class="form-group">
          <label>Your Name</label>
          <input type="text" name="name" placeholder="e.g. Priya Ramesh" required>
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" name="email" placeholder="e.g. priya@example.com" required>
        </div>
        <div class="form-group">
          <label>Phone Number</label>
          <input type="tel" name="phone" placeholder="+91 9384784409" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Occasion</label>
            <select name="occasion">
              <option>Birthday</option>
              <option>Wedding</option>
              <option>Anniversary</option>
              <option>Baby Shower</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-group">
            <label>Delivery Date</label>
            <input type="date" name="delivery_date" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Flavour Preference</label>
            <select name="flavour">
              <option>Choco truffle</option>
              <option>Lotus Biscoff</option>
              <option>Black Forest</option>
              <option>White Forest</option>
              <option>Salted Caramel</option>
              <option>Mango</option>
              <option>Blueberry</option>
            </select>
          </div>
          <div class="form-group">
            <label>Weight</label>
            <select name="weight">
              <option>0.5 kg</option>
              <option>1.0 kg</option>
              <option>2.0 kg</option>
              <option>3.0+ kg</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
            <input type="checkbox" name="eggless" id="eggless" style="width: auto;">
            <label for="eggless" style="margin: 0; padding-top: 5px;">Eggless</label>
          </div>
          <div class="form-group" style="display: flex; align-items: center; gap: 10px;">
            <input type="checkbox" name="urgent" id="urgent" style="width: auto;">
            <label for="urgent" style="margin: 0; padding-top: 5px;">Urgent Order</label>
          </div>
        </div>
        <div class="form-group">
          <label>Delivery/Pickup Time</label>
          <input type="time" name="delivery_time" required>
        </div>
        <div class="form-group">
          <label>Reference Image (Optional)</label>
          <input type="file" name="reference_image" accept="image/*" style="background: white;">
        </div>
        <div class="form-group">
          <label>Payment Method</label>
          <select name="payment_method" id="custom-method" required>
            <option value="UPI">Online Payment (Rs. 50 Advance)</option>
            <option value="COD">Cash on Delivery</option>
          </select>
        </div>
        <div class="form-group">
          <label>Custom Message & Instructions</label>
          <textarea name="message" placeholder="Message on cake, design ideas..." required></textarea>
        </div>
        <button type="submit" class="btn-primary" style="width:100%" id="submitOrderBtn">
          Send Request
        </button>
        <p style="font-size: 0.75rem; color: var(--text-muted); text-align: center; margin-top: 10px;">
          You will be redirected to WhatsApp to confirm your order details.
        </p>
      </form>
    </div>
  </div>
</section>

